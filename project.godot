; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GPU Cloth Sim"
run/main_scene="uid://c7xsi0e240i40"
config/features=PackedStringArray("4.5")

[autoload]

ClaudeBridge="*res://addons/claude_bridge/game_bridge.gd"

[dotnet]

project/assembly_name="GPU Cloth Sim"

[editor_plugins]

enabled=PackedStringArray("res://addons/claude_bridge/plugin.cfg", "res://addons/godot_gpu_cloth/plugin.cfg")

[rendering]

lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=3
anti_aliasing/quality/msaa_3d=2
anti_aliasing/quality/screen_space_aa=1
